# Docker local stack — copy to .env
#   cp .env.docker.example .env
#   docker compose up -d --build
#
# Redis + Pinecone run in Compose. LLM defaults to Ollama on the Windows host
# (install Ollama + pull qwen3:14b on D:; see scripts/setup_ollama.ps1).

# --- LLM (local dev: Ollama on host; override to groq + GROQ_API_KEY for cloud LLM) ---
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=qwen3:14b
# GROQ_API_KEY=

# --- Local stack (set by docker-compose.yml; override only if needed) ---
REDIS_BACKEND=local
REDIS_URL=redis://redis:6379/0

PINECONE_MODE=local
PINECONE_API_KEY=pclocal
PINECONE_HOST=pinecone.local
PINECONE_PORT=5081
PINECONE_INDEX_NAME=boolmind-knowledge-bge

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# --- FIDP in Docker CPU image (no GPU) ---
IMAGE_GEN_PROVIDER=mock

# --- Optional Tier B+ (cloud) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# HUBSPOT_ACCESS_TOKEN=
# CALCOM_API_KEY=
# RESEND_API_KEY=
# SUPABASE_URL=
# POSTHOG_API_KEY=
# SENTRY_DSN=

APP_NAME=Boolmind AI Advisor
DEBUG=false
