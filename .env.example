# ---------------------------------------------------------------------------
# Boolmind AI Advisor — copy to .env and fill in your secrets
#   copy .env.example .env
# Never commit .env. Placeholders only in this file.
# ---------------------------------------------------------------------------

# =============================================================================
# Tier A — Phase 1 (chat + RAG + sessions)
# =============================================================================

# --- Groq (LLM: chat + tool calling) ---
# At least one key required: primary and/or numbered pool (rotation on 429)
GROQ_API_KEY=
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
# Number of numbered keys to use (1..N). 0 = auto (all non-empty GROQ_API_KEY_N)
GROQ_KEY_POOL_SIZE=0
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.7
GROQ_MAX_TOKENS=4096

# --- Embeddings (local BGE — default; no API key) ---
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384

# --- OpenAI embeddings (only if EMBEDDING_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Pinecone (must match EMBEDDING_DIMENSION: 384 for BGE small) ---
# PINECONE_MODE=cloud | local (Docker stack uses local + pinecone-index container)
PINECONE_MODE=cloud
PINECONE_API_KEY=
PINECONE_INDEX_NAME=boolmind-knowledge-bge
PINECONE_HOST=
PINECONE_PORT=5081

# --- Redis sessions ---
# REDIS_BACKEND=upstash | local (Docker stack uses local Redis container)
REDIS_BACKEND=upstash
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Tier B — Phase 3 (leads, booking, security, database)
# =============================================================================

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=jhoiqryisvxvtafvdwcf

HUBSPOT_ACCESS_TOKEN=
HUBSPOT_PIPELINE_ID=
HUBSPOT_STAGE_NEW_LEAD=

CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=
CALCOM_BOOKING_TIMEZONE=UTC

RESEND_API_KEY=
RESEND_FROM_EMAIL=advisor@boolmind.ai
RESEND_FROM_NAME=Boolmind.AI Advisor

CHAT_API_SECRET=
CHAT_RATE_LIMIT_PER_MINUTE=20

# =============================================================================
# Tier C — Phase 4 (analytics + errors)
# =============================================================================

POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=

SENTRY_DSN=

# =============================================================================
# Tier D — Phase 6 (FIDP images)
# =============================================================================

REPLICATE_API_TOKEN=
# FIDP: mock | replicate | local (SDXL Turbo on GPU — run scripts/setup_gpu.ps1 first)
IMAGE_GEN_PROVIDER=local
IMAGE_GEN_MODEL=stabilityai/sdxl-turbo
IMAGE_GEN_STEPS=2
IMAGE_GEN_SIZE=512

# Model + generated image cache on D: (recommended; C: often low on space)
HF_HOME=D:\boolmind-ai\ml-cache
FIDP_OUTPUT_DIR=D:\boolmind-ai\fidp-output
# Optional: HF_TOKEN=  # faster Hugging Face downloads

# =============================================================================
# App
# =============================================================================

APP_NAME=Boolmind AI Advisor
DEBUG=false
KNOWLEDGE_BASE_PATH=knowledge-base

# =============================================================================
# Legacy voice (optional)
# =============================================================================

# DEEPGRAM_API_KEY=
# TTS_PROVIDER=deepgram
# STT_PROVIDER=deepgram
