# ---------------------------------------------------------------------------
# Boolmind AI – copy to .env and fill in your keys
# ---------------------------------------------------------------------------

# --- Groq (LLM) ---
GROQ_API_KEY=

# Optional Groq defaults
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_TEMPERATURE=0.7
# GROQ_MAX_TOKENS=4096

# --- App ---
# APP_NAME=AI Backend
# DEBUG=false
# KNOWLEDGE_BASE_PATH=knowledge
# VOICE_RICH_LOGS=false

# --- Voice: TTS & STT providers ---
# TTS: chatterbox | elevenlabs | deepgram
# STT: webkit (client-only) | deepgram
# TTS_PROVIDER=deepgram
# STT_PROVIDER=deepgram

# Chatterbox TTS (local server)
# CHATTERBOX_TTS_URL=http://localhost:4123

# ElevenLabs (when TTS_PROVIDER=elevenlabs)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Deepgram (STT and/or TTS)
DEEPGRAM_API_KEY=

# Optional Deepgram defaults
# DEEPGRAM_STT_MODEL=nova-2
# DEEPGRAM_TTS_MODEL=aura-asteria-en
