      "id": 2,
      "title": "Tool duration p95",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (tool, le) (rate(advisor_tool_duration_seconds_bucket[5m])))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
